# Copy to .env and adjust. Never commit real secrets.

# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Asia/Tehran

# --- Database (default: sqlite). For Postgres set DB_ENGINE=postgres ---
# DB_ENGINE=postgres
# DB_NAME=legal_assistant
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# --- Legal Assistant providers (real data for the delivered app) ---
LAWYER_REPO_PROVIDER=orm
EVALUATION_REPO_PROVIDER=orm
DOCUMENT_STORE_PROVIDER=orm
# LLM stays fake until a real provider adapter exists; set true to make /ask
# refuse rather than answer with the fake provider.
LLM_PROVIDER=fake
API_REQUIRE_REAL_LLM=false

# --- Frontend (Next.js) ---
# Server-side base URL the Next.js app uses to reach the API.
API_BASE_URL=http://localhost:8000
