# Copy to .env and adjust. Never commit real secrets.
# docker compose reads this file automatically for ${VAR} interpolation.

# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_TIME_ZONE=Asia/Tehran

# --- Database ---
# Compose defaults to Postgres (DB_ENGINE=postgres, DB_HOST=postgres).
# Leave DB_ENGINE unset to use local SQLite when running outside Docker.
DB_ENGINE=postgres
DB_NAME=persian_legal_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# --- Legal Assistant providers (real data for the delivered app) ---
LAWYER_REPO_PROVIDER=orm
EVALUATION_REPO_PROVIDER=orm
DOCUMENT_STORE_PROVIDER=orm
LEGAL_JURISDICTION=IR

# --- Models / LLM ---
# LLM stays fake until a real provider adapter exists; set API_REQUIRE_REAL_LLM
# true to make /ask refuse rather than answer with the fake provider.
LLM_PROVIDER=fake
LLM_MODEL_NAME=
API_REQUIRE_REAL_LLM=false
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL_NAME=MCINext/Hakim-small
OPENAI_API_KEY=

# --- Frontend (Next.js) ---
# API_BASE_URL is set to http://web:8000 inside compose; override for local dev.
API_BASE_URL=http://localhost:8000
SITE_URL=http://localhost:3008

# --- Docker host ports (change if a port is already taken on the host) ---
WEB_PORT=8008
UI_PORT=3008
DB_HOST_PORT=5433

# --- Future services (uncomment when adapters exist) ---
# QDRANT_URL=http://qdrant:6333
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=please-change
# REDIS_URL=redis://redis:6379/0
