# Copy to .env and adjust. Never commit real secrets.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change
NEO4J_DATABASE=neo4j
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687

# PDF embedding and vector indexing
OPENAI_API_KEY=
OPENAI_API_BASE=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=64
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
LEGAL_FILES_QDRANT_COLLECTION=novinlaw_legal_files
GRAPH_RAG_QDRANT_COLLECTION=legal_graph_nodes
QDRANT_HOST_PORT=6333
DOCUMENT_CHUNK_CHARS=4000
DOCUMENT_CHUNK_OVERLAP_CHARS=300

# Citation-grounded legal research agent
AGENT_MODEL_PROVIDER=openai
AGENT_MODEL_NAME=gpt-5-mini
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2
OPENAI_USE_RESPONSES_API=false
AGENT_MAX_SEARCH_RESULTS=8
AGENT_MAX_GRAPH_DEPTH=2
AGENT_MAX_GRAPH_RESULTS=16
AGENT_MAX_TOOL_CALLS=4
AGENT_RECURSION_LIMIT=24
AGENT_MAX_EVIDENCE_CHARS=4000
AGENT_MAX_QUESTION_CHARS=12000
AGENT_MAX_HISTORY_MESSAGES=20
