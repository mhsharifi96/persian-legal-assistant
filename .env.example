# Copy to .env and adjust. Never commit real secrets.
# docker compose reads this file automatically for ${VAR} interpolation.

# --- Django ---
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web
DJANGO_TIME_ZONE=Asia/Tehran

# --- Database ---
# Compose defaults to Postgres (DB_ENGINE=postgres, DB_HOST=postgres).
# Leave DB_ENGINE unset to use local SQLite when running outside Docker.
DB_ENGINE=postgres
DB_NAME=persian_legal_assistant
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432

# --- Legal Assistant providers (real data for the delivered app) ---
LAWYER_REPO_PROVIDER=orm
EVALUATION_REPO_PROVIDER=orm
DOCUMENT_STORE_PROVIDER=orm
LEGAL_JURISDICTION=IR

# --- Models / LLM ---
# Real AI/RAG profile. Set both API keys before enabling LangSmith tracing.
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-5.6
API_REQUIRE_REAL_LLM=true
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
VECTORSTORE_PROVIDER=qdrant
GRAPHSTORE_PROVIDER=neo4j
OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_TIMEOUT_SECONDS=60
OPENAI_MAX_RETRIES=2

# --- Retrieval stores ---
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=persian_legal_chunks
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=please-change
NEO4J_DATABASE=neo4j

# --- LangSmith observability (opt in) ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=persian-legal-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Legal questions can contain sensitive facts. Keep payload masking enabled
# unless your data policy explicitly permits sending trace inputs/outputs.
LANGSMITH_HIDE_INPUTS=true
LANGSMITH_HIDE_OUTPUTS=true

# --- Frontend (Next.js) ---
# API_BASE_URL is set to http://web:8000 inside compose; override for local dev.
API_BASE_URL=http://localhost:8000
SITE_URL=http://localhost:3008

# --- Docker host ports (change if a port is already taken on the host) ---
WEB_PORT=8008
UI_PORT=3008
DB_HOST_PORT=5433
QDRANT_HOST_PORT=6333
NEO4J_HTTP_HOST_PORT=7474
NEO4J_BOLT_HOST_PORT=7687

# --- Future services ---
# REDIS_URL=redis://redis:6379/0
